{
  "name": "workflow-black-box",
  "version": "0.1.0",
  "description": "Visual automation diagnostics console for n8n, Zapier and Make workflows, with MCP tools for agents.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/IAZARA/workflow-black-box.git"
  },
  "homepage": "https://github.com/IAZARA/workflow-black-box#readme",
  "keywords": [
    "automation",
    "workflow",
    "diagnostics",
    "n8n",
    "zapier",
    "make",
    "mcp",
    "react",
    "typescript",
    "docker"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "check:mcp": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution Bundler --skipLibCheck mcp/server.ts src/lib/analyzer.ts",
    "mcp": "tsx mcp/server.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3"
  }
}
